generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum PlaylistKind {
  MAIN
  ARCHIVE
}

enum LifecycleStatus {
  ACTIVE
  REMOVED
}

enum SyncRunStatus {
  RUNNING
  SUCCESS
  PARTIAL
  FAILED
}

enum SyncTriggerSource {
  MANUAL
  GITHUB_ACTIONS
  CRON
  SETUP
}

enum CommentAttachmentKind {
  IMAGE
  AUDIO
}

enum CommentAttachmentStatus {
  PENDING
  READY
  FAILED
  BLOCKED
}

enum CommentModerationState {
  VISIBLE
  HIDDEN
}

model AdminAccount {
  spotifyUserId         String   @id
  displayName           String?
  profileUrl            String?
  accessTokenEncrypted  String
  refreshTokenEncrypted String
  tokenExpiresAt        DateTime
  grantedScopes         String[]
  lastAuthenticatedAt   DateTime @default(now())
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model UserAccount {
  spotifyUserId         String      @id
  displayName           String?
  profileUrl            String?
  accessTokenEncrypted  String
  refreshTokenEncrypted String
  tokenExpiresAt        DateTime
  grantedScopes         String[]
  lastAuthenticatedAt   DateTime    @default(now())
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
  spotifyUser           SpotifyUser @relation(fields: [spotifyUserId], references: [spotifyUserId], onDelete: Cascade)
}

model SpotifyUser {
  spotifyUserId   String           @id
  displayName     String?
  profileUrl      String?
  addedLifecycles TrackLifecycle[] @relation("LifecycleContributor")
  songComments    SongComment[]    @relation("SongCommentAuthor")
  userAccount     UserAccount?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model Playlist {
  spotifyPlaylistId String            @id
  name              String
  kind              PlaylistKind
  ownerSpotifyUserId String?
  ownerDisplayName  String?
  isPublic          Boolean           @default(false)
  collaborative     Boolean           @default(false)
  canRead           Boolean           @default(false)
  canWrite          Boolean           @default(false)
  snapshotId        String?
  lastValidatedAt   DateTime?
  lifecycles        TrackLifecycle[]
  archiveEntries    ArchiveEntry[]
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
}

model Track {
  spotifyTrackId String           @id
  name           String
  nameRomanized  String?
  artistNames    String[]
  artistNamesRomanized String[]   @default([])
  artistSpotifyUrls String[]      @default([])
  albumName      String?
  artworkUrl     String?
  spotifyUrl     String
  spotifyUri     String
  durationMs     Int?
  explicit       Boolean?
  lifecycles     TrackLifecycle[]
  archiveEntries ArchiveEntry[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
}

model TrackLifecycle {
  id                  String           @id @default(cuid())
  playlistSpotifyId   String
  trackSpotifyId      String
  addedBySpotifyUserId String?
  spotifyAddedAt      DateTime?
  firstSeenAt         DateTime
  lastSeenAt          DateTime
  removedObservedAt   DateTime?
  status              LifecycleStatus  @default(ACTIVE)
  matchFingerprint    String
  occurrenceOrdinal   Int
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  playlist            Playlist         @relation(fields: [playlistSpotifyId], references: [spotifyPlaylistId], onDelete: Cascade)
  track               Track            @relation(fields: [trackSpotifyId], references: [spotifyTrackId], onDelete: Cascade)
  addedBy             SpotifyUser?     @relation("LifecycleContributor", fields: [addedBySpotifyUserId], references: [spotifyUserId], onDelete: SetNull)

  @@index([playlistSpotifyId, status])
  @@index([playlistSpotifyId, matchFingerprint, occurrenceOrdinal])
  @@index([trackSpotifyId, status])
}

model ArchiveEntry {
  playlistSpotifyId String
  trackSpotifyId    String
  createdAt         DateTime @default(now())
  playlist          Playlist @relation(fields: [playlistSpotifyId], references: [spotifyPlaylistId], onDelete: Cascade)
  track             Track    @relation(fields: [trackSpotifyId], references: [spotifyTrackId], onDelete: Cascade)

  @@id([playlistSpotifyId, trackSpotifyId])
}

model SongComment {
  id                         String                  @id
  trackSpotifyId             String
  threadRootId               String
  parentCommentId            String?
  authorSpotifyUserId        String
  authorDisplayNameSnapshot  String?
  authorProfileUrlSnapshot   String?
  authorImageUrlSnapshot     String?
  clientSubmissionId         String
  timestampMs                Int
  markerBucketSecond         Int
  body                       String
  replyCount                 Int                     @default(0)
  attachmentCount            Int                     @default(0)
  moderationState            CommentModerationState?
  deletedAt                  DateTime?
  createdAt                  DateTime                @default(now())
  updatedAt                  DateTime                @updatedAt
  author                     SpotifyUser             @relation("SongCommentAuthor", fields: [authorSpotifyUserId], references: [spotifyUserId], onDelete: Restrict)
  threadRoot                 SongComment             @relation("SongCommentThreadRoot", fields: [threadRootId], references: [id], onDelete: Cascade)
  threadComments             SongComment[]           @relation("SongCommentThreadRoot")
  parentComment              SongComment?            @relation("SongCommentReplies", fields: [parentCommentId], references: [id], onDelete: Cascade)
  replies                    SongComment[]           @relation("SongCommentReplies")
  attachments                SongCommentAttachment[]

  @@index([trackSpotifyId, markerBucketSecond])
  @@index([trackSpotifyId, timestampMs])
  @@index([threadRootId, createdAt])
  @@index([parentCommentId, createdAt])
  @@index([authorSpotifyUserId, createdAt])
  @@unique([authorSpotifyUserId, clientSubmissionId])
}

model SongCommentAttachment {
  id          String                  @id
  commentId   String
  kind        CommentAttachmentKind
  storageUrl  String
  mimeType    String?
  byteSize    Int?
  durationMs  Int?
  status      CommentAttachmentStatus @default(PENDING)
  createdAt   DateTime                @default(now())
  comment     SongComment             @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@index([commentId, createdAt])
}

model SyncRun {
  id                       String            @id @default(cuid())
  triggerSource            SyncTriggerSource
  status                   SyncRunStatus     @default(RUNNING)
  playlistSpotifyId        String
  startedAt                DateTime
  completedAt              DateTime?
  fetchedItemsCount        Int               @default(0)
  activeItemsCount         Int               @default(0)
  additionsCount           Int               @default(0)
  removalsCount            Int               @default(0)
  archiveQueuedCount       Int               @default(0)
  archiveSuccessCount      Int               @default(0)
  archiveFailureCount      Int               @default(0)
  notificationSuccessCount Int               @default(0)
  notificationFailureCount Int               @default(0)
  warnings                 String[]
  errors                   String[]
}

model AppSettings {
  id                     Int      @id @default(1)
  mainPlaylistId         String
  archivePlaylistId      String
  syncIntervalMinutes    Int      @default(60)
  discordWebhookUrl      String?
  notifyOnAdditions      Boolean  @default(false)
  notifyOnRemovals       Boolean  @default(false)
  batchedNotifications   Boolean  @default(true)
  archiveDedupeEnabled   Boolean  @default(true)
  publicDashboard        Boolean  @default(true)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}
